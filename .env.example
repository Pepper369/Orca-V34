# Recommended for local + Netlify + Cloudflare Pages compatibility
# Use a Neon Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST/DBNAME?sslmode=require

# Secret for calling cron routes manually
CRON_SECRET=replace-with-a-long-random-secret

# Skip new snapshot creation if the latest one is still fresh
MIN_UPDATE_INTERVAL_MINUTES=50

# Kept for compatibility / documentation
PG_POOL_MAX=5

# Use Neon driver everywhere to stay compatible with Edge / Cloudflare Pages
DB_DRIVER=neon
